#!/bin/bash
# KOPPA-OS: Post-install hook ‚ÄĒ runs inside chroot during ISO build
set -e

echo "[KOPPA-OS] Setting up KOPPA Language..."

# Install KOPPA from PyPI
pip3 install --no-cache-dir koppa-lang pygls lsprotocol 2>/dev/null || true

# Install Metasploit if not in package list (Debian repo may not have it)
if ! command -v msfconsole &>/dev/null; then
  curl -fsSL https://apt.metasploit.com/metasploit-framework.gpg | \
    gpg --dearmor -o /usr/share/keyrings/metasploit.gpg 2>/dev/null || true
  echo "deb [signed-by=/usr/share/keyrings/metasploit.gpg] \
    https://apt.metasploit.com/ buster main" \
    > /etc/apt/sources.list.d/metasploit.list 2>/dev/null || true
  apt-get update -qq 2>/dev/null && \
    apt-get install -y metasploit-framework 2>/dev/null || true
fi

# Pre-install KOPPA security packages
python3 -m koppa pkg install koppa-portscan  2>/dev/null || true
python3 -m koppa pkg install koppa-jwt-attack 2>/dev/null || true
python3 -m koppa pkg install koppa-subdomain  2>/dev/null || true
python3 -m koppa pkg install koppa-hashcrack  2>/dev/null || true
python3 -m koppa pkg install koppa-webfuzz    2>/dev/null || true

# MOTD
cat > /etc/motd << 'MOTD'

