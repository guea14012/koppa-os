# ── Wireless ──────────────────────────────────────────────────────────────────
cat > "$APP_DIR/koppa-aircrack.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Aircrack-ng
Comment=WiFi network security assessment suite
Exec=xfce4-terminal --title="aircrack-ng" -e "aircrack-ng --help; bash"
