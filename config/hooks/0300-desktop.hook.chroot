#!/bin/bash
# KOPPA-OS: Desktop environment — .desktop files, panel, prompt, neofetch
# NOTE: set -e intentionally omitted; non-critical steps use || true

echo "[KOPPA-OS] Setting up desktop environment..."

APP_DIR="/usr/share/applications"
TERMINAL="xfce4-terminal"

# ══════════════════════════════════════════════════════════════════════════════
# .desktop Files — organized by KOPPA security category
# ══════════════════════════════════════════════════════════════════════════════

# ── KOPPA Tools ───────────────────────────────────────────────────────────────
cat > "$APP_DIR/koppa-repl.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=KOPPA REPL
Comment=Interactive KOPPA Security Shell
Exec=xfce4-terminal --title="KOPPA REPL" -e "koppa repl"
Icon=/usr/share/icons/koppa-os/koppa-os.png
Terminal=false
Categories=KOPPA;Security;
Keywords=koppa;repl;shell;pentest;
EOF

cat > "$APP_DIR/koppa-c2.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=KOPPA C2 Server
Comment=HTTP/DNS Command & Control Server
Exec=xfce4-terminal --title="KOPPA-C2" -e "koppa-c2 0.0.0.0 8443"
Icon=/usr/share/icons/koppa-os/koppa-os.png
Terminal=false
Categories=KOPPA;Security;C2;
Keywords=c2;command;control;http;dns;
EOF

cat > "$APP_DIR/koppa-pkg.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=KOPPA Package Manager
Comment=Install KOPPA security modules
Exec=xfce4-terminal --title="KOPPA Packages" -e "koppa pkg list"
Icon=/usr/share/icons/koppa-os/koppa-os.png
Terminal=false
Categories=KOPPA;Security;PackageManager;
Keywords=koppa;package;install;modules;
EOF

# ── Network Recon ─────────────────────────────────────────────────────────────
cat > "$APP_DIR/koppa-nmap.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Nmap
Comment=Network Mapper — port scan and service detection
Exec=xfce4-terminal --title="nmap" -e "nmap -h; bash"
Icon=network-wired
Terminal=false
Categories=NetworkRecon;Security;
Keywords=nmap;scan;port;network;recon;
EOF

cat > "$APP_DIR/koppa-masscan.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Masscan
Comment=Mass IP port scanner — fastest in the world
Exec=xfce4-terminal --title="masscan" -e "masscan --help; bash"
Icon=network-wired
Terminal=false
Categories=NetworkRecon;Security;
Keywords=masscan;scan;port;fast;
EOF

cat > "$APP_DIR/koppa-wireshark.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Wireshark
Comment=Network packet analyzer
Exec=wireshark
Icon=wireshark
Terminal=false
Categories=NetworkRecon;Security;
Keywords=wireshark;packet;capture;network;
EOF

cat > "$APP_DIR/koppa-tcpdump.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=tcpdump
Comment=Command-line packet capture
Exec=xfce4-terminal --title="tcpdump" -e "tcpdump --help; bash"
Icon=network-wired
Terminal=false
Categories=NetworkRecon;Security;
Keywords=tcpdump;packet;capture;
EOF

