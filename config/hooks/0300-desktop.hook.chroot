cat > "$APP_DIR/koppa-volatility.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Volatility3
Comment=Memory forensics framework
Exec=xfce4-terminal --title="volatility3" -e "python3 -m volatility3 -h; bash"
Icon=applications-science
Terminal=false
