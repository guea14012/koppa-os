#!/bin/sh
# KOPPA-OS: Set passwords — runs as LAST live-config hook (9999)

# Wait for user creation to complete
sleep 2

# Root
echo "root:koppa" | chpasswd 2>/dev/null || true

# uid 1000 user (whoever live-config created)
LIVE_USER=$(getent passwd 1000 | cut -d: -f1 2>/dev/null || true)
if [ -n "$LIVE_USER" ]; then
    echo "${LIVE_USER}:koppa" | chpasswd 2>/dev/null || true
    echo "${LIVE_USER} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/99-koppa-live
    chmod 440 /etc/sudoers.d/99-koppa-live
fi

# Explicit fallback for all common live usernames
for u in user vboxuser live koppa; do
    id "$u" >/dev/null 2>&1 && echo "${u}:koppa" | chpasswd 2>/dev/null || true
done

# Restart LightDM AFTER passwords are set so autologin works
sleep 1
systemctl restart lightdm 2>/dev/null || true
