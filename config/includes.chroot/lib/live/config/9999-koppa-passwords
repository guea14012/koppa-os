#!/bin/sh
# KOPPA-OS live-config hook — runs on every boot
# Sets password "koppa" for root and every live user that live-config created

# Root always gets koppa
echo "root:koppa" | chpasswd 2>/dev/null || true

# Find whatever live user was created (uid 1000)
LIVE_USER=$(getent passwd 1000 | cut -d: -f1 2>/dev/null || true)

if [ -n "$LIVE_USER" ]; then
    echo "${LIVE_USER}:koppa" | chpasswd 2>/dev/null || true
    # Full sudo without password
    echo "${LIVE_USER} ALL=(ALL) NOPASSWD:ALL" \
        > /etc/sudoers.d/koppa-live-user
    chmod 440 /etc/sudoers.d/koppa-live-user
fi

# Cover common live usernames explicitly
for u in user vboxuser live koppa; do
    id "$u" >/dev/null 2>&1 && echo "${u}:koppa" | chpasswd 2>/dev/null || true
done
