#!/bin/bash
# KOPPA Language runner
# Tries PyPI install first, then bundled version
if python3 -c "import koppa" 2>/dev/null; then
    exec python3 -m koppa "$@"
elif [ -f /usr/share/koppa/src/koppa.py ]; then
    exec python3 /usr/share/koppa/src/koppa.py "$@"
else
    echo "KOPPA not found. Install: pip3 install koppa-lang"
    exit 1
fi
